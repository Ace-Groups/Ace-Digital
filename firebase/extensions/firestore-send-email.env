# Firebase Extension: Trigger Email from Firestore
# Install once per project:
#   firebase ext:install firebase/firestore-send-email --project ace-digital-os
#
# Uses the `mail` collection (see artifacts/api-server/src/lib/email.ts).
# DEFAULT_FROM should match a sender allowed by your SMTP / extension config.

MAIL_COLLECTION=mail
DEFAULT_FROM=Ace-Digital <no-reply@acedigital.com>
