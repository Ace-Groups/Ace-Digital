# Copy to `.env` in this directory:  cp .env.example .env
# Used by drizzle-kit push (local Postgres) and local API when USE_FIRESTORE is not set.

# Local Postgres (see docker-compose.yml)
DATABASE_URL=postgresql://ace:ace_dev_password@localhost:5432/ace_digital

# Local API (optional — defaults shown)
# PORT=8080
# JWT_SECRET=dev-secret-change-me-min-32-chars-long
# USE_FIRESTORE=false

# Frontend dev proxy — where Vite forwards /api and /socket.io
# Default (if unset): https://ace-digital-api.onrender.com (production API)
# For fully local stack: VITE_DEV_API_PROXY=http://localhost:8080

# Production uses Firestore on Render — drizzle push is NOT required there.
# USE_FIRESTORE=true

# Gemini AI (Render API — server-side only, never expose to Vite)
# GEMINI_API_KEY=your-google-ai-api-key
# GEMINI_API_KEY_FALLBACK=optional-second-key-when-primary-quota-exhausted
# GEMINI_MODEL=gemini-2.0-flash
# Do not use gemini-flash-latest — requires prepay credits on many accounts.
# OPENROUTER_API_KEY=sk-or-...   — fallback when Gemini fails (free tier at openrouter.ai)
# OPENROUTER_MODEL=openrouter/free
# OPENROUTER_HTTP_REFERER=https://ace-digital-os.web.app
# AI_MAX_TOOL_ITERATIONS=8
# AI_RATE_LIMIT_PER_USER_PER_HOUR=60
