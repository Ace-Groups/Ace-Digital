# Copy to `.env` in this directory:  cp .env.example .env
# Used by drizzle-kit push (local Postgres) and local API when USE_FIRESTORE is not set.

# Local Postgres (see docker-compose.yml)
DATABASE_URL=postgresql://ace:ace_dev_password@localhost:5432/ace_digital

# Local API (optional — defaults shown)
# PORT=8080
# JWT_SECRET=dev-secret-change-me-min-32-chars-long
# USE_FIRESTORE=false

# Production uses Firestore on Render — drizzle push is NOT required there.
# USE_FIRESTORE=true
