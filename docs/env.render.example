# Render web service (ace-digital-api) — environment template
# Copy keys into Render Dashboard → Environment. Do not commit real values.

NODE_ENV=production
PORT=10000

# Required: same signing secret as production JWT issuance
JWT_SECRET=replace-with-32-plus-char-secret

# Firestore (production DB)
USE_FIRESTORE=true
GCLOUD_PROJECT=ace-digital-os
# Paste full service account JSON as a single line:
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# CORS: allow Firebase Hosting origins
CORS_ORIGINS=https://acedigital.cc,https://www.acedigital.cc,https://ace-digital-os.web.app,https://ace-digital-os.firebaseapp.com

# Render build only (set in dashboard, not runtime):
# SKIP_INSTALL_DEPS=true
